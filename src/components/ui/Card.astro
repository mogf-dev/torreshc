---
import type { Service } from "@data/services";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article
  class="service-card flex-shrink-0 w-full md:w-[520px] bg-white rounded-2xl overflow-hidden border border-dark/8 shadow-sm group"
>
  <div class="relative h-64 overflow-hidden">
    <img
      src={service.image}
      alt={service.title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent">
    </div>
    <span
      class="absolute bottom-4 left-5 text-white text-xl font-bold tracking-tight"
    >
      {service.title}
    </span>
  </div>

  <div class="p-6 flex flex-col gap-4">
    <p class="text-dark/65 text-sm leading-relaxed">
      {service.description}
    </p>

    <ul class="flex flex-col gap-2">
      {
        service.highlights.map((h) => (
          <li class="flex items-center gap-2 text-sm text-dark/80">
            <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0" />
            {h}
          </li>
        ))
      }
    </ul>
  </div>
</article>
