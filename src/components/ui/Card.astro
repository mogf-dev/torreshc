---
import type { Service } from "@data/services";
import { Image } from "astro:assets";

import service1 from "../../assets/images/service1.webp";
import service2 from "../../assets/images/service2.webp";
import service3 from "../../assets/images/service3.webp";
import service4 from "../../assets/images/service4.webp";
import service5 from "../../assets/images/service5.webp";

const serviceImages: Record<string, ImageMetadata> = {
  "/images/service1.webp": service1,
  "/images/service2.webp": service2,
  "/images/service3.webp": service3,
  "/images/service4.webp": service4,
  "/images/service5.webp": service5,
};

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article
  class="service-card shrink-0 w-full md:w-130 bg-white rounded-2xl overflow-hidden border border-dark/8 shadow-sm group hover:shadow-xl hover:shadow-dark/8 transition-all duration-500"
>
  <div class="relative h-64 overflow-hidden">
    <Image
      src={serviceImages[service.image]}
      alt={service.title}
      width={520}
      height={256}
      quality={75}
      format="webp"
      loading="lazy"
      decoding="async"
      sizes="(max-width: 768px) 100vw, 520px"
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-115"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-dark/70 via-dark/20 to-transparent"
    >
    </div>
    <span class="absolute bottom-4 left-5 text-white text-xl tracking-tight">
      {service.title}
    </span>
    <!-- Shine effect -->
    <div
      class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
      style="background:linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);"
    >
    </div>
  </div>

  <div class="p-6 flex flex-col gap-4">
    <p class="text-dark/65 text-sm leading-relaxed">
      {service.description}
    </p>

    <ul class="flex flex-col gap-2.5">
      {
        service.highlights.map((h) => (
          <li class="flex items-center gap-2.5 text-sm text-dark/80">
            <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />
            {h}
          </li>
        ))
      }
    </ul>
  </div>
</article>
