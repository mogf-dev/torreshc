---
import Icon from "@ui/Icon.astro";

type IconName = string; // keyof typeof ICONS — usa el tipo exacto si lo tienes

interface Props {
  icon?: IconName;
  title: string;
  description: string;
  span?: string;
  variant?: "default" | "dark" | "accent";
  stat?: string;
  statLabel?: string;
}

const {
  icon,
  title,
  description,
  span = "",
  variant = "default",
  stat,
  statLabel,
} = Astro.props;

const variantClasses = {
  default: "bg-white border border-dark/8 text-dark",
  dark: "bg-dark text-white",
  accent: "bg-primary text-white",
};

const iconColor =
  variant === "default" ? "var(--primary)" : "rgba(255,255,255,0.8)";
---

<div
  class:list={[
    "relative rounded-2xl p-7 flex flex-col justify-between gap-4 overflow-hidden transition-transform duration-200 hover:-translate-y-0.5",
    variantClasses[variant],
    span,
  ]}
>
  <!-- Decorative bg on dark variant -->
  {
    variant === "dark" && (
      <div
        class="absolute inset-0 opacity-5 pointer-events-none"
        style="background: radial-gradient(circle at top right, #D97706 0%, transparent 60%);"
      />
    )
  }

  <div class="flex flex-col gap-4 relative z-10">
    <!-- Icon -->
    {
      icon && (
        <span
          class:list={[
            "w-10 h-10 rounded-xl flex items-center justify-center",
            variant === "default" ? "bg-muted/8" : "bg-white/10",
          ]}
        >
          <Icon name={icon as any} color={iconColor} size={20} />
        </span>
      )
    }

    <div class="flex flex-col gap-2">
      <h3
        class:list={[
          "text-lg font-semibold leading-snug",
          variant === "default" ? "text-dark" : "text-white",
        ]}
      >
        {title}
      </h3>
      <p
        class:list={[
          "text-sm leading-relaxed",
          variant === "default" ? "text-dark/60" : "text-white/70",
        ]}
      >
        {description}
      </p>
    </div>
  </div>

  {
    stat && (
      <div class="relative z-10 mt-auto">
        <p
          class:list={[
            "text-5xl font-black tracking-tighter leading-none",
            variant === "default" ? "text-primary" : "text-white",
          ]}
        >
          {stat}
        </p>
        {statLabel && (
          <p
            class:list={[
              "text-xs mt-1 font-medium uppercase tracking-widest",
              variant === "default" ? "text-dark/40" : "text-white/50",
            ]}
          >
            {statLabel}
          </p>
        )}
      </div>
    )
  }
</div>
