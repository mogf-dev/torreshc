---
export interface Props {
  variant?: "primary" | "outline" | "ghost";
  type?: "button" | "submit" | "reset";
  href?: string;
  newTab?: boolean;
  fullWidth?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  type = "button",
  href,
  newTab = false,
  fullWidth = false,
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 px-7 py-2.5 text-sm font-medium rounded-full cursor-pointer no-underline transition-all duration-300 hover:scale-[1.03] active:scale-[0.97] focus-visible:outline focus-visible:outline-1 focus-visible:outline-primary focus-visible:outline-offset-2 relative overflow-hidden";

const variants = {
  primary: "bg-primary border border-primary text-white shadow-md shadow-primary/20 hover:shadow-lg hover:shadow-primary/30 hover:bg-primary/95",
  outline: "bg-dark/5 border border-dark/50 text-dark hover:bg-dark hover:text-white hover:border-dark transition-all duration-300",
  ghost:
    "bg-transparent border-transparent text-dark opacity-50 px-2 hover:bg-dark/5 hover:opacity-100",
};

const classes = [base, variants[variant], fullWidth ? "w-full" : ""].join(" ");
---

{
  href ? (
    <a
      href={href}
      target={newTab ? "_blank" : undefined}
      rel={newTab ? "noopener noreferrer" : undefined}
      class:list={[classes, className]}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class:list={[classes, className]} {...rest}>
      <slot />
    </button>
  )
}
