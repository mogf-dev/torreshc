---
export interface Props {
  variant?: "primary" | "outline" | "ghost";
  type?: "button" | "submit" | "reset";
  href?: string;
  newTab?: boolean;
  fullWidth?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = "primary",
  type = "button",
  href,
  newTab = false,
  fullWidth = false,
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 px-7 py-3 text-sm font-semibold tracking-[0.08em] uppercase rounded-full cursor-pointer no-underline transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] focus-visible:outline focus-visible:outline-1 focus-visible:outline-primary focus-visible:outline-offset-2 relative overflow-hidden";

const variants = {
  primary:
    "bg-primary border border-primary text-white shadow-[0_18px_40px_-20px_rgba(184,92,56,0.9)] hover:shadow-[0_22px_48px_-20px_rgba(184,92,56,0.95)] hover:bg-primary-deep hover:border-primary-deep",
  outline:
    "bg-transparent border border-dark/16 text-dark hover:bg-dark hover:text-[var(--color-surface)] hover:border-dark transition-all duration-300",
  ghost:
    "bg-transparent border-transparent text-dark/60 opacity-80 px-2 hover:bg-dark/5 hover:text-dark hover:opacity-100",
};

const classes = [base, variants[variant], fullWidth ? "w-full" : ""].join(" ");
---

{
  href ? (
    <a
      href={href}
      target={newTab ? "_blank" : undefined}
      rel={newTab ? "noopener noreferrer" : undefined}
      class:list={[classes, className]}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class:list={[classes, className]} {...rest}>
      <slot />
    </button>
  )
}
