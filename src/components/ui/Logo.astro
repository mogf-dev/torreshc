---
import logo from "@/assets/logo.svg";

interface Props {
  size?: number;
  variant?: "light" | "dark";
}

const { size = 20, variant = "dark" } = Astro.props;

const textColor = variant === "light" ? "text-white/90" : "text-dark/80";
---

<div class="flex items-center gap-2" style={`--logo-size:${size}px`}>
  <div
    class="flex items-center shrink-0"
    style={`width:${size}px; height:${size}px`}
  >
    <img src={logo.src} alt="Torres Home logo" class="block w-full h-full" />
  </div>

  <div
    translate="no"
    class={`flex flex-col items-center leading-none ${textColor}`}
  >
    <span class="text-md uppercase tracking-widest font-medium">
      Torres Home
    </span>
  </div>
</div>
