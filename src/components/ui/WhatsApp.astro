---
import Icon from "./Icon.astro";

interface Props {
  phone: string;
  message?: string;
}

const { phone, message = "Hi! I'd like a quote for my project." } = Astro.props;
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  id="whatsapp-btn"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat on WhatsApp"
  class="whatsapp-btn fixed bottom-6 right-6 z-50 flex items-center gap-2.5 px-5 py-3 rounded-full shadow-lg transition-all duration-300 hover:scale-105 active:scale-95 group"
>
  <!-- WhatsApp icon -->
  <Icon name="whatsapp" />

  <span
    class="whatsapp-label text-sm font-semibold leading-none transition-colors duration-300"
  >
    Chat
  </span>
</a>

<style>
  /* Default: dark button (on light sections) */
  .whatsapp-btn {
    background-color: var(--color-dark);
    color: var(--color-surface);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
  }

  .whatsapp-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* On dark sections: flip to surface (white) */
  .whatsapp-btn.on-dark {
    background-color: var(--color-surface);
    color: var(--color-dark);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  const btn = document.getElementById("whatsapp-btn")!;
  const contact = document.getElementById("contact");

  function update() {
    if (!contact) return;
    // Switch to light when the top of #contact enters the viewport
    const onDark = contact.getBoundingClientRect().top <= window.innerHeight;
    btn.classList.toggle("on-dark", onDark);
  }

  window.addEventListener("scroll", update, { passive: true });
  update();
</script>
