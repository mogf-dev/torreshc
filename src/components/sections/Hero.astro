---
// src/components/sections/Hero.astro
import Button from "@ui/Button.astro";
import Badge from "@ui/Badge.astro";

const photos = [
  {
    src: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=700&h=900&q=80",
    alt: "Modern home exterior",
  },
  {
    src: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=500&h=360&q=80",
    alt: "Interior painting finish",
  },
  {
    src: "https://images.unsplash.com/photo-1631889993959-41b4e9c6e3c5?auto=format&fit=crop&w=500&h=360&q=80",
    alt: "Bathroom renovation",
  },
];

const stats = [
  { value: "+50", label: "Projects delivered" },
  { value: "2022", label: "Founded" },
  { value: "100%", label: "Client satisfaction" },
];
---

<section
  id="hero"
  class="relative bg-[#FAFAF9] overflow-hidden"
  style="min-height: 100svh;"
>
  <!-- Subtle grain -->
  <div
    class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');background-size:180px;"
  >
  </div>

  <!-- Amber glow — top right, behind photos -->
  <div
    class="absolute top-0 right-0 w-150 h-150 -translate-y-1/4 translate-x-1/4 rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(217,119,6,0.12) 0%, transparent 70%);"
  >
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-5 md:px-10 grid md:grid-cols-[1fr_auto] gap-10 items-center"
    style="min-height:100svh; padding-top:5rem; padding-bottom:4rem;"
  >
    <!-- ── LEFT ─────────────────────────────────────────── -->
    <div class="flex flex-col gap-8 max-w-xl">
      <div class="hero-el" style="--d:0.05s">
        <Badge variant="soft">USA · Est. 2022</Badge>
      </div>

      <h1
        class="hero-el font-serif text-[clamp(3rem,6vw,5.5rem)] leading-[1.06] tracking-tight text-dark"
        style="--d:0.15s"
      >
        We build<br />
        the <span class="text-primary italic">space</span><br />
        you imagined.
      </h1>

      <p
        class="hero-el text-[1.0625rem] text-dark/55 leading-relaxed max-w-104"
        style="--d:0.27s"
      >
        Quality-first construction, remodeling, and interior design. From
        blueprint to finished space — on time and on budget.
      </p>

      <div class="hero-el flex flex-wrap gap-3" style="--d:0.37s">
        <Button href="#contact" variant="primary">Get a free quote</Button>
        <Button href="#gallery" variant="outline">See our work</Button>
      </div>

      <!-- Stats -->
      <div
        class="hero-el grid grid-cols-3 gap-6 pt-2 border-t border-dark/8 mt-2"
        style="--d:0.48s"
      >
        {
          stats.map((s) => (
            <div class="flex flex-col gap-1.5">
              <span class="text-2xl md:text-[2rem] font-black text-dark leading-none tracking-tight">
                {s.value}
              </span>
              <span class="text-xs text-dark/40 leading-tight">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- ── RIGHT: collage ─────────────────────────────── -->
    <div
      class="hero-el hidden md:block relative w-110 xl:w-125"
      style="--d:0.22s; height: min(700px, calc(100svh - 9rem));"
    >
      <!-- Tall left photo -->
      <div
        class="absolute left-0 top-0 bottom-0 w-[54%] rounded-2xl overflow-hidden shadow-[0_20px_60px_-10px_rgba(0,0,0,0.18)]"
      >
        <img
          src={photos[0].src}
          alt={photos[0].alt}
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Top-right photo — starts at 10% from top -->
      <div
        class="absolute right-0 top-[5%] h-[47%] w-[43%] rounded-2xl overflow-hidden shadow-[0_16px_48px_-8px_rgba(0,0,0,0.15)]"
      >
        <img
          src={photos[1].src}
          alt={photos[1].alt}
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Bottom-right photo — ends at 95% -->
      <div
        class="absolute right-0 bottom-[3%] h-[47%] w-[43%] rounded-2xl overflow-hidden shadow-[0_16px_48px_-8px_rgba(0,0,0,0.15)]"
      >
        <img
          src={photos[2].src}
          alt={photos[2].alt}
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Floating badge — sits between the two right photos -->
      <div
        class="hero-badge-float absolute left-[48%] top-1/2 -translate-y-1/2 -translate-x-2 bg-white rounded-xl shadow-[0_8px_32px_-4px_rgba(0,0,0,0.18)] px-4 py-3 flex items-center gap-3 z-20 opacity-0 w-max"
      >
        <span
          class="w-8 h-8 rounded-full bg-primary/12 flex items-center justify-center text-primary text-sm shrink-0"
          >✓</span
        >
        <div>
          <p class="text-xs font-bold text-dark leading-none">
            Licensed & Insured
          </p>
          <p class="text-[11px] text-dark/45 mt-1">North Carolina</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-dark/25"
  >
    <span class="text-[9px] uppercase tracking-[0.25em]">Scroll</span>
    <div class="w-px h-7 bg-dark/15 relative overflow-hidden rounded-full">
      <div
        class="absolute top-0 left-0 w-full h-1/2 bg-dark/40 rounded-full animate-bounce"
      >
      </div>
    </div>
  </div>
</section>

<style>
  .font-serif,
  h1.font-serif {
    font-family: "Playfair Display Variable", Georgia, serif;
  }

  /* Entrance */
  .hero-el {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s),
      transform 0.65s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s);
  }
  .hero-el.in {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-badge-float {
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.72s,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.72s;
  }
  .hero-badge-float.in {
    opacity: 1 !important;
    transform: translate(-0.5rem, -50%) !important;
  }
</style>

<script>
  const els = document.querySelectorAll<HTMLElement>("#hero .hero-el");
  const badge = document.querySelector<HTMLElement>("#hero .hero-badge-float");

  function reveal() {
    requestAnimationFrame(() => {
      els.forEach((el) => el.classList.add("in"));
      badge?.classList.add("in");
    });
  }

  document.readyState === "complete"
    ? reveal()
    : window.addEventListener("load", reveal);
</script>
