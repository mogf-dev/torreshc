---
// src/components/sections/Hero.astro
import Button from "@ui/Button.astro";
import Badge from "@ui/Badge.astro";

// Unsplash placeholder — replace with your real image
const HERO_BG =
  "https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1800&q=80";

const stats = [
  { value: "2022", label: "Founded" },
  { value: "+50", label: "Projects delivered" },
  { value: "100%", label: "Client satisfaction" },
];
---

<section
  id="hero"
  class="relative min-h-screen flex items-end md:items-center overflow-hidden"
>
  <!-- Background image -->
  <div class="absolute inset-0 -z-10">
    <img
      src={HERO_BG}
      alt="Torres Construction project"
      class="w-full h-full object-cover"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.55) 50%, rgba(10,10,10,0.20) 100%);"
    >
    </div>
  </div>

  <!-- Main content -->
  <div
    class="relative z-10 w-full max-w-7xl mx-auto px-5 md:px-10 pb-20 md:pb-0 pt-28"
  >
    <div class="max-w-3xl flex flex-col gap-6">
      <Badge variant="outline" color="white">USA · Est. 2022</Badge>

      <h1
        class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-[1.08] tracking-tight font-serif"
      >
        We build the<br />
        <span class="text-primary">space</span> you<br />
        imagined.
      </h1>

      <p class="text-base md:text-lg text-white/70 max-w-xl leading-relaxed">
        Quality-first construction, remodeling, and interior design. We take
        your vision from blueprint to finished space — on time and on budget.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <Button href="#contact" variant="primary"> Get a free quote </Button>
        <Button href="#gallery" variant="outline"> See our work </Button>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-14 md:mt-20 grid grid-cols-3 gap-4 max-w-lg">
      {
        stats.map((s) => (
          <div class="flex flex-col gap-0.5 border-l-2 border-primary/60 pl-3">
            <span class="text-2xl md:text-3xl font-black text-white leading-none">
              {s.value}
            </span>
            <span class="text-[11px] md:text-xs text-white/55 leading-tight">
              {s.label}
            </span>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-white/40"
  >
    <span class="text-[10px] uppercase tracking-[0.2em]">Scroll</span>
    <div class="w-px h-8 bg-white/30 relative overflow-hidden">
      <div
        class="absolute top-0 left-0 w-full h-1/2 bg-white/60 animate-bounce"
      >
      </div>
    </div>
  </div>
</section>
