---
// src/components/sections/Gallery.astro
import Section from "@ui/Section.astro";
import { gallery } from "@data/gallery";

// Show only first 6 in the preview grid
const PREVIEW_COUNT = 6;
const preview = gallery.slice(0, PREVIEW_COUNT);
const categories = [
  "All",
  "Drywall",
  "Painting",
  "Flooring",
  "Carpentry",
  "Renovations",
] as const;
---

<section id="gallery" class="py-24 bg-[#F7F7F5]">
  <div class="max-w-7xl mx-auto px-5 md:px-10 flex flex-col gap-12">
    <!-- Header -->
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
    >
      <Section
        align="left"
        badge="Our work"
        title="Projects that speak for themselves"
        description="A curated selection of our Drywall, Painting, Flooring, Carpentry and Renovation work."
      />
    </div>

    <!-- Preview grid with fade -->
    <div class="relative">
      <div
        id="masonry-preview"
        class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4"
      >
        {
          preview.map((item) => (
            <div
              class="preview-item break-inside-avoid overflow-hidden rounded-xl group relative cursor-pointer"
              data-id={item.id}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-300 flex items-end p-4">
                <span class="text-white text-sm font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                  {item.alt}
                </span>
              </div>
              <span class="absolute top-3 left-3 px-2.5 py-0.5 bg-white/90 text-dark text-[11px] font-semibold rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {item.category}
              </span>
            </div>
          ))
        }
      </div>

      <!-- Fade overlay -->
      <div
        class="absolute bottom-0 left-0 right-0 h-48 pointer-events-none"
        style="background: linear-gradient(to top, #F7F7F5 10%, transparent 100%);"
      >
      </div>
    </div>

    <!-- CTA -->
    <div class="flex justify-center -mt-4">
      <button
        id="open-gallery-btn"
        class="inline-flex items-center gap-2 px-6 py-3 bg-dark text-white text-sm font-medium rounded-full hover:bg-dark/85 transition-colors duration-200"
      >
        View all projects
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 8h10M9 4l4 4-4 4"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- ── LIGHTBOX MODAL ─────────────────────────────────────────────────── -->
<div
  id="gallery-modal"
  class="fixed inset-0 z-[100] bg-dark/60 backdrop-blur-sm hidden items-center justify-center p-4 md:p-8"
  role="dialog"
  aria-modal="true"
  aria-label="Photo gallery"
>
  <!-- Panel -->
  <div
    class="relative bg-dark rounded-2xl w-full max-w-6xl max-h-[90vh] flex flex-col overflow-hidden shadow-2xl"
  >
    <!-- Modal header -->
    <div
      class="flex items-center justify-between px-5 md:px-8 py-5 border-b border-white/8 shrink-0"
    >
      <div class="flex flex-wrap gap-2" id="modal-filters">
        {
          categories.map((cat) => (
            <button
              class="modal-filter-btn px-4 py-1.5 text-sm rounded-full border transition-all duration-200"
              data-cat={cat}
            >
              {cat}
            </button>
          ))
        }
      </div>
      <button
        id="close-gallery-btn"
        aria-label="Close gallery"
        class="w-9 h-9 rounded-full bg-white/8 flex items-center justify-center text-white/60 hover:bg-white/15 hover:text-white transition-all duration-200 shrink-0 ml-4"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="3" x2="13" y2="13"></line><line
            x1="13"
            y1="3"
            x2="3"
            y2="13"></line>
        </svg>
      </button>
    </div>

    <!-- Modal grid -->
    <div class="flex-1 overflow-y-auto px-5 md:px-8 py-6">
      <div
        id="modal-grid"
        class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4"
      >
        {
          gallery.map((item) => (
            <div
              class="modal-item break-inside-avoid overflow-hidden rounded-xl group relative cursor-pointer"
              data-cat={item.category}
              data-id={item.id}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/60 transition-all duration-300 flex items-end p-4">
                <span class="text-white text-sm font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300 leading-snug">
                  {item.alt}
                </span>
              </div>
              <span class="absolute top-3 left-3 px-2.5 py-0.5 bg-white/90 text-dark text-[11px] font-semibold rounded-full backdrop-blur-sm">
                {item.category}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div><!-- /Panel -->
</div>

<style>
  /* Preview item cursor */
  .preview-item {
    cursor: default;
  }

  /* Modal filter buttons */
  .modal-filter-btn {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.55);
  }
  .modal-filter-btn:hover,
  .modal-filter-btn.active {
    background: #ffffff;
    border-color: #ffffff;
    color: #111111;
  }

  /* Prevent body scroll when modal open — position:fixed keeps the page
     in place while overflow:hidden locks it. The JS saves/restores scrollY. */
  body.modal-open {
    position: fixed;
    left: 0;
    right: 0;
    overflow-y: scroll; /* keep scrollbar gutter so layout doesn't shift */
  }
</style>

<script>
  const openBtn = document.getElementById("open-gallery-btn")!;
  const closeBtn = document.getElementById("close-gallery-btn")!;
  const modal = document.getElementById("gallery-modal")!;
  const modalItems = document.querySelectorAll<HTMLElement>(".modal-item");
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".modal-filter-btn");

  let savedScrollY = 0;

  // Open — save scroll position, lock body in place
  openBtn.addEventListener("click", () => {
    savedScrollY = window.scrollY;
    document.body.style.top = `-${savedScrollY}px`;
    document.body.classList.add("modal-open");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    filterBtns[0]?.click();
  });

  // Close — restore scroll position exactly
  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.classList.remove("modal-open");
    document.body.style.top = "";
    window.scrollTo({ top: savedScrollY, behavior: "instant" });
  }

  closeBtn.addEventListener("click", closeModal);

  // Close on backdrop click (outside modal content)
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // Filters
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const cat = btn.dataset.cat!;
      modalItems.forEach((item) => {
        item.style.display =
          cat === "All" || item.dataset.cat === cat ? "" : "none";
      });
    });
  });
</script>
