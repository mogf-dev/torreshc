---
import Section from "@ui/Section.astro";
import { gallery } from "@data/gallery";
import Button from "../ui/Button.astro";

const PREVIEW_COUNT = 6;
const preview = gallery.slice(0, PREVIEW_COUNT);
const categories = [
  "All",
  "Drywall",
  "Painting",
  "Flooring",
  "Carpentry",
  "Renovations",
] as const;
---

<section id="gallery" class="py-24 bg-white relative overflow-hidden">
  <!-- Ambient gradient -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-150 h-100 pointer-events-none opacity-30" style="background:radial-gradient(ellipse at center, rgba(221,38,25,0.1) 0%, transparent 70%);"></div>
  
  <div class="max-w-7xl mx-auto px-5 md:px-10 flex flex-col gap-12 relative z-10">
    <!-- Header -->
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
    >
      <Section
        align="left"
        badge="Our work"
        title="Projects that speak for themselves"
        description="A curated selection of our Drywall, Painting, Flooring, Carpentry and Renovation work."
      />
    </div>

    <!-- Preview grid with fade -->
    <div class="relative">
      <div
        id="masonry-preview"
        class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4"
      >
        {
          preview.map((item) => (
            <div
              class="preview-item break-inside-avoid overflow-hidden rounded-xl group relative cursor-pointer"
              data-id={item.id}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full h-auto object-cover transition-transform duration-700 ease-out group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-linear-to-t from-dark/70 via-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end p-4">
                <span class="text-white text-sm font-medium translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                  {item.alt}
                </span>
              </div>
              <span class="absolute top-3 left-3 px-2.5 py-0.5 bg-white/90 text-dark text-[11px] font-semibold rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 shadow-lg">
                {item.category}
              </span>
              <!-- Corner accent -->
              <div class="absolute top-0 right-0 w-12 h-12 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style="background:linear-gradient(135deg, transparent 50%, rgba(255,255,255,0.3) 50%);"></div>
            </div>
          ))
        }
      </div>

      <!-- Fade overlay -->
      <div
        class="absolute bottom-0 left-0 right-0 h-48 pointer-events-none"
        style="background: linear-gradient(to top, var(--color-white) 10%, transparent 100%);"
      >
      </div>
    </div>

    <!-- CTA -->
    <div class="flex justify-center -mt-4">
      <Button
        id="open-gallery-btn"
      >
        View all projects
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-x-1"
        >
          <path d="M3 8h10M9 4l4 4-4 4"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>

<!-- ── LIGHTBOX MODAL ─────────────────────────────────────────────────── -->

<!-- Backdrop: always in DOM, toggled via opacity so backdrop-filter never breaks -->
<div
  id="gallery-backdrop"
  class="fixed inset-0 z-99 pointer-events-none opacity-0 transition-opacity duration-300 gallery-backdrop"
  style="background:rgba(0,0,0,0.65);"
>
</div>

<!-- Modal wrapper: hidden/flex toggle, no blur on this element -->
<div
  id="gallery-modal"
  class="fixed inset-0 z-100 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Photo gallery"
>
  <!-- ── DESKTOP: centered panel (md+) ── -->
  <div
    id="gallery-panel-desktop"
    class="hidden md:flex items-center justify-center w-full h-full p-8"
  >
    <div
      class="bg-white rounded-2xl w-full max-w-6xl flex flex-col overflow-hidden shadow-2xl"
      style="max-height:min(90dvh,90vh);"
    >
      <!-- Header -->
      <div
        class="flex items-center justify-between px-6 py-4 border-b border-dark/8 shrink-0"
      >
        <div class="flex flex-wrap gap-2" id="modal-filters-desktop">
          {
            categories.map((cat) => (
              <button
                class="filter-btn px-4 py-1.5 text-sm rounded-full border transition-all duration-200"
                data-cat={cat}
              >
                {cat}
              </button>
            ))
          }
        </div>
        <button
          id="close-desktop"
          aria-label="Close"
          class="w-9 h-9 rounded-full bg-dark/6 flex items-center justify-center text-dark/50 hover:bg-dark/10 hover:text-dark transition-all shrink-0 ml-4"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            ><line x1="2" y1="2" x2="12" y2="12"></line><line
              x1="12"
              y1="2"
              x2="2"
              y2="12"></line></svg
          >
        </button>
      </div>

      <!-- Grid -->
      <div class="flex-1 overflow-y-auto px-6 py-6">
        <div
          class="columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4"
          id="modal-grid-desktop"
        >
          {
            gallery.map((item) => (
              <div
                class="modal-item break-inside-avoid overflow-hidden rounded-xl group relative"
                data-cat={item.category}
              >
                <img
                  src={item.src}
                  alt={item.alt}
                  loading="lazy"
                  class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-300 flex items-end p-3">
                  <span class="text-white text-xs font-medium opacity-0 group-hover:opacity-100 translate-y-1 group-hover:translate-y-0 transition-all duration-300">
                    {item.alt}
                  </span>
                </div>
                <span class="absolute top-2 left-2 px-2 py-0.5 bg-white/90 text-dark text-[10px] font-semibold rounded-full">
                  {item.category}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- ── MOBILE: bottom sheet (up to md) ── -->
  <div
    id="gallery-sheet"
    class="md:hidden absolute bottom-0 left-0 right-0 bg-white rounded-t-2xl flex flex-col shadow-2xl"
    style="max-height:90dvh; height:90dvh;"
  >
    <!-- Handle — tap or drag down to close -->
    <div
      id="sheet-handle"
      class="flex justify-center pt-3 pb-2 shrink-0 cursor-pointer active:opacity-60"
      aria-label="Close"
      role="button"
    >
      <div class="w-10 h-1 bg-dark/20 rounded-full"></div>
    </div>

    <!-- Filters -->
    <div
      class="filters-mobile flex items-center gap-2 px-4 pb-3 border-b border-dark/8 shrink-0 overflow-x-auto"
      id="modal-filters-mobile"
      style="-webkit-overflow-scrolling:touch;"
    >
      {
        categories.map((cat) => (
          <button
            class="filter-btn shrink-0 px-4 py-1.5 text-sm rounded-full border transition-all duration-200"
            data-cat={cat}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <!-- Grid -->
    <div
      class="flex-1 overflow-y-auto px-4 py-4"
      style="-webkit-overflow-scrolling:touch;"
    >
      <div class="columns-2 gap-3 space-y-3" id="modal-grid-mobile">
        {
          gallery.map((item) => (
            <div
              class="modal-item break-inside-avoid overflow-hidden rounded-xl group relative"
              data-cat={item.category}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full h-auto object-cover"
              />
              <span class="absolute top-2 left-2 px-2 py-0.5 bg-white/90 text-dark text-[10px] font-semibold rounded-full">
                {item.category}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Close bar -->
    <div class="shrink-0 px-4 py-4 border-t border-dark/8">
      <button
        id="close-mobile"
        class="w-full py-3 bg-dark text-white text-sm font-semibold rounded-xl hover:bg-dark/85 transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</div>

<style>
  .preview-item {
    cursor: default;
  }

  .filter-btn {
    background: transparent;
    border-color: rgba(17, 17, 17, 0.15);
    color: rgba(17, 17, 17, 0.55);
    white-space: nowrap;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #111111;
    border-color: #111111;
    color: #ffffff;
  }

  /* Blur only on desktop */
  @media (min-width: 768px) {
    .gallery-backdrop {
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
  }

  /* Bottom sheet — CSS owns all transform/transition */
  #gallery-sheet {
    transform: translateY(100%);
    transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }
  #gallery-sheet.open {
    transform: translateY(0);
  }

  /* Backdrop fades in/out smoothly */
  #gallery-backdrop {
    transition: opacity 0.3s ease;
  }

  /* Lock body scroll */
  body.modal-open {
    position: fixed;
    left: 0;
    right: 0;
    overflow-y: scroll;
  }

  /* Mobile horizontal filter scrollbar — thin, transparent track, gray thumb */
  .filters-mobile {
    scrollbar-width: thin;
    scrollbar-color: rgba(17, 17, 17, 0.25) transparent;
  }
  .filters-mobile::-webkit-scrollbar {
    height: 2px;
  }
  .filters-mobile::-webkit-scrollbar-track {
    background: transparent;
  }
  .filters-mobile::-webkit-scrollbar-thumb {
    background: rgba(17, 17, 17, 0.22);
    border-radius: 2px;
  }
</style>

<script>
  const openBtn = document.getElementById("open-gallery-btn")!;
  const modal = document.getElementById("gallery-modal")!;
  const backdrop = document.getElementById("gallery-backdrop")!;
  const sheet = document.getElementById("gallery-sheet")!;
  const sheetHandle = document.getElementById("sheet-handle")!;
  const closeDesktop = document.getElementById("close-desktop")!;
  const closeMobile = document.getElementById("close-mobile")!;
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const modalItems = document.querySelectorAll<HTMLElement>(".modal-item");

  let savedScrollY = 0;

  // Start hidden
  modal.style.display = "none";

  // ── Open ───────────────────────────────────────────────
  function openModal() {
    savedScrollY = window.scrollY;
    document.body.style.top = `-${savedScrollY}px`;
    document.body.classList.add("modal-open");
    modal.style.display = "flex";

    requestAnimationFrame(() => {
      backdrop.style.opacity = "1";
      requestAnimationFrame(() => sheet.classList.add("open"));
    });

    filterBtns[0]?.click();
  }

  // ── Close ──────────────────────────────────────────────
  function closeModal() {
    // 1. Backdrop fades out
    backdrop.style.opacity = "0";
    backdrop.style.pointerEvents = "none";

    // 2. Sheet slides down
    sheet.classList.remove("open");

    // 3. Hide wrapper only after CSS transition finishes (380ms)
    setTimeout(() => {
      modal.style.display = "none";
    }, 380);

    // 4. Restore page scroll immediately (feels snappier)
    document.body.classList.remove("modal-open");
    document.body.style.top = "";
    window.scrollTo({ top: savedScrollY, behavior: "instant" });
  }

  openBtn.addEventListener("click", openModal);
  closeDesktop.addEventListener("click", closeModal);
  closeMobile.addEventListener("click", closeModal);

  // Handle tap → close
  sheetHandle.addEventListener("click", closeModal);

  // Handle drag-down → close (touch)
  let dragStartY = 0;
  sheetHandle.addEventListener(
    "touchstart",
    (e) => {
      dragStartY = e.touches[0].clientY;
    },
    { passive: true },
  );
  sheetHandle.addEventListener(
    "touchend",
    (e) => {
      const delta = e.changedTouches[0].clientY - dragStartY;
      if (delta > 40) closeModal(); // swiped down 40px+
    },
    { passive: true },
  );

  // Desktop backdrop click → close
  backdrop.addEventListener("click", () => {
    if (window.innerWidth >= 768) closeModal();
  });

  // Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // Filters
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const cat = btn.dataset.cat!;
      filterBtns.forEach((b) =>
        b.classList.toggle("active", b.dataset.cat === cat),
      );
      modalItems.forEach((item) => {
        item.style.display =
          cat === "All" || item.dataset.cat === cat ? "" : "none";
      });
    });
  });
</script>
