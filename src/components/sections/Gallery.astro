---
// src/components/sections/Gallery.astro
import Section from "@ui/Section.astro";
import { gallery } from "@data/gallery";

const categories = ["All", ...new Set(gallery.map((g) => g.category))];
---

<section id="gallery" class="py-24 bg-[#F7F7F5]">
  <div class="max-w-7xl mx-auto px-5 md:px-10 flex flex-col gap-12">
    <!-- Header -->
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
    >
      <Section
        align="left"
        badge="Our work"
        title="Projects that speak for themselves"
        description="A curated selection of residential, commercial, and remodeling work."
      />

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2" id="gallery-filters">
        {
          categories.map((cat) => (
            <button
              class="filter-btn px-4 py-1.5 text-sm rounded-full border transition-all duration-200"
              data-cat={cat}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Masonry — CSS columns -->
    <div
      id="masonry-grid"
      class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4"
    >
      {
        gallery.map((item) => (
          <div
            class="gallery-item break-inside-avoid overflow-hidden rounded-xl group relative cursor-pointer"
            data-cat={item.category}
          >
            <img
              src={item.src}
              alt={item.alt}
              loading="lazy"
              class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-300 flex items-end p-4">
              <span class="text-white text-sm font-medium opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                {item.alt}
              </span>
            </div>
            <span class="absolute top-3 left-3 px-2.5 py-0.5 bg-white/90 text-dark text-[11px] font-semibold rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              {item.category}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .filter-btn {
    background: transparent;
    border-color: rgba(17, 17, 17, 0.15);
    color: rgba(17, 17, 17, 0.6);
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #111111;
    border-color: #111111;
    color: #ffffff;
  }
</style>

<script>
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".gallery-item");

  filterBtns[0]?.classList.add("active");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const cat = btn.dataset.cat!;
      items.forEach((item) => {
        item.style.display =
          cat === "All" || item.dataset.cat === cat ? "" : "none";
      });
    });
  });
</script>
