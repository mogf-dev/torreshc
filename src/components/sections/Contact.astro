---
// src/components/sections/Contact.astro
import Logo from "@ui/Logo.astro";
import IconLink from "@ui/IconLink.astro";
import Icon from "@ui/Icon.astro";

type IconName = "phone" | "mail" | "location";

interface ContactItem {
  label: string;
  value: string;
  href: string;
  icon: IconName;
}

const contactInfo: ContactItem[] = [
  {
    label: "Call us",
    value: "704 277 5688",
    href: "tel:+17042775688",
    icon: "phone",
  },
  {
    label: "Email",
    value: "info@torreshc.com",
    href: "mailto:info@torreshc.com",
    icon: "mail",
  },
  {
    label: "Location",
    value: "North Carolina, United States",
    href: "https://maps.google.com/?q=North+Carolina",
    icon: "location",
  },
];

const startYear = 2022;
const year = new Date().getFullYear();
const yearRange = year > startYear ? `${startYear}–${year}` : `${startYear}`;
---

<section id="contact" class="bg-dark text-white">
  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-5 md:px-10 py-20">
    <div class="grid md:grid-cols-2 gap-16 md:gap-0">
      <!-- Left: brand -->
      <div class="flex flex-col gap-7 md:pr-16 md:border-r border-white/8">
        <Logo size={24} variant="light" />
        <p class="text-sm text-white/50 leading-relaxed max-w-120">
          Quality construction and remodeling across the USA. Building with
          excellence since 2022.
        </p>
        <div>
          <p class="text-[10px] uppercase text-white/30 font-semibold mb-5">
            Follow us
          </p>
          <div class="flex items-center">
            <IconLink
              name="instagram"
              href="https://instagram.com"
              label="Instagram"
            />
            <IconLink
              name="facebook"
              href="https://facebook.com"
              label="Facebook"
            />
            <IconLink name="tiktok" href="https://tiktok.com" label="TikTok" />
          </div>
        </div>
      </div>

      <!-- Right: contact items -->
      <div class="flex flex-col gap-1 md:pl-16">
        <p
          class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-5"
        >
          Contact
        </p>
        {
          contactInfo.map((info) => (
            <a
              href={info.href}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-item flex items-center gap-4 px-3 py-3.5 rounded-xl group transition-all duration-200"
            >
              <span class="w-10 h-10 rounded-xl bg-white/6 flex items-center justify-center text-white/40 group-hover:bg-primary group-hover:text-white transition-all duration-200 shrink-0">
                <Icon name={info.icon} size={18} />
              </span>
              <div class="flex flex-col gap-0.5">
                <p class="text-[10px] text-white/30 uppercase tracking-widest font-semibold">
                  {info.label}
                </p>
                <p class="text-white/75 text-sm font-medium group-hover:text-white transition-colors">
                  {info.value}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <style>
    .contact-item:hover {
      background: rgba(255, 255, 255, 0.04);
    }
    section .social-link {
      color: rgba(255, 255, 255, 0.45);
    }
    section .socials:hover {
      background: rgba(255, 255, 255, 0.08);
    }
  </style>
</section>
