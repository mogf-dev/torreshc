---
import Section from "@ui/Section.astro";
import Card from "@ui/Card.astro";
import { services } from "@data/services";
---

<section id="services" class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle ambient -->
  <div class="absolute top-1/2 left-0 w-[500px] h-[500px] -translate-y-1/2 pointer-events-none opacity-40" style="background:radial-gradient(ellipse at center, rgba(221,38,25,0.04) 0%, transparent 70%);"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] pointer-events-none opacity-30" style="background:radial-gradient(ellipse at center, rgba(26,47,55,0.05) 0%, transparent 70%);"></div>
  
  <div class="max-w-7xl mx-auto px-5 md:px-10 flex flex-col gap-12 relative z-10">
    <!-- Header row -->
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
    >
      <Section
        align="left"
        badge="Our services"
        title="Everything your project needs"
        description="From concept to completion — we manage every phase with the same level of care."
      />

      <!-- Controls -->
      <div class="flex items-center gap-3 shrink-0">
        <button
          id="prev-btn"
          aria-label="Previous service"
          class="carousel-btn w-11 h-11 rounded-full border border-dark/15 flex items-center justify-center text-dark/50 hover:border-dark/40 hover:text-dark hover:bg-dark/5 transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="11,4 6,9 11,14"></polyline>
          </svg>
        </button>
        <button
          id="next-btn"
          aria-label="Next service"
          class="carousel-btn w-11 h-11 rounded-full bg-primary border border-primary flex items-center justify-center text-white hover:bg-primary/90 transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed shadow-md shadow-primary/20"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="7,4 12,9 7,14"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <!-- Carousel track -->
    <div id="carousel-viewport" class="relative overflow-hidden">
      <div
        id="carousel-track"
        class="flex gap-5 transition-transform duration-500 ease-in-out will-change-transform"
      >
        {services.map((service) => <Card service={service} />)}
      </div>
    </div>

    <!-- Progress dots (built by JS) -->
    <div id="dots-container" class="flex justify-center gap-2"></div>
  </div>
</section>

<script>
  const viewport = document.getElementById("carousel-viewport") as HTMLElement;
  const track = document.getElementById("carousel-track") as HTMLElement;
  const dotsContainer = document.getElementById(
    "dots-container",
  ) as HTMLElement;
  const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
  const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;

  let current = 0;
  let dots: HTMLButtonElement[] = [];

  function cardWidth(): number {
    const card = track.querySelector<HTMLElement>(".service-card");
    return card ? card.offsetWidth + 20 : 0;
  }

  function computeMaxIndex(): number {
    const cw = cardWidth();
    if (cw <= 0) return 0;
    // How many full cards fit (min 1 — on mobile cards are w-full so
    // cw > viewportWidth and plain floor would give 0)
    const visible = Math.max(1, Math.floor(viewport.offsetWidth / cw));
    // Last scrollable index = total cards - visible (minimum 0)
    return Math.max(
      0,
      track.querySelectorAll<HTMLElement>(".service-card").length - visible,
    );
  }

  function buildDots(maxIndex: number) {
    dotsContainer.innerHTML = "";
    dots = [];
    for (let i = 0; i <= maxIndex; i++) {
      const btn = document.createElement("button");
      btn.className =
        "dot w-1.5 h-1.5 rounded-full bg-dark/20 transition-all duration-300";
      btn.setAttribute("aria-label", `Go to slide ${i + 1}`);
      btn.addEventListener("click", () => goTo(i));
      dotsContainer.appendChild(btn);
      dots.push(btn);
    }
  }

  function goTo(index: number) {
    const cw = cardWidth();
    const max = Math.max(0, track.scrollWidth - viewport.offsetWidth);
    const maxIndex = computeMaxIndex();

    current = Math.max(0, Math.min(index, maxIndex));

    // Raw offset, capped to max so last slide is flush
    const offset = Math.min(cw * current, max);
    track.style.transform = `translateX(-${offset}px)`;

    dots.forEach((d, i) => {
      const active = i === current;
      d.classList.toggle("bg-primary", active);
      d.classList.toggle("w-4", active);
      d.classList.toggle("bg-dark/20", !active);
      d.classList.toggle("w-1.5", !active);
    });

    prevBtn.disabled = current <= 0;
    nextBtn.disabled = current >= maxIndex;
  }

  function init() {
    buildDots(computeMaxIndex());
    goTo(0);
  }

  prevBtn.addEventListener("click", () => goTo(current - 1));
  nextBtn.addEventListener("click", () => goTo(current + 1));

  let startX = 0;
  track.addEventListener(
    "touchstart",
    (e) => {
      startX = e.touches[0].clientX;
    },
    { passive: true },
  );
  track.addEventListener("touchend", (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) diff > 0 ? goTo(current + 1) : goTo(current - 1);
  });

  window.addEventListener(
    "resize",
    () => {
      buildDots(computeMaxIndex());
      goTo(Math.min(current, computeMaxIndex()));
    },
    { passive: true },
  );

  if (document.readyState === "complete") {
    init();
  } else {
    window.addEventListener("load", init);
  }
</script>
