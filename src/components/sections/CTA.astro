---
import Button from "../ui/Button.astro";
---

<section
  id="cta"
  class="cta-section py-32 md:py-44 bg-bg overflow-hidden relative"
>
  <!-- Ambient backgrounds -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-200 h-125 pointer-events-none opacity-40"
    style="background:radial-gradient(ellipse at center, rgba(221,38,25,0.05) 0%, transparent 70%);"
  >
  </div>

  <div
    class="max-w-5xl mx-auto px-5 md:px-10 text-center flex flex-col items-center relative z-10"
  >
    <!-- Eyebrow -->
    <p
      class="cta-eyebrow text-[11px] uppercase tracking-[0.25em] text-dark/35 font-semibold mb-10 opacity-0"
    >
      Ready to build?
    </p>

    <!-- Headline — each word is a reveal unit -->
    <h2
      class="cta-headline text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-[-0.04em] text-dark font-display"
    >
      <span class="word">Your</span>
      <span class="word">next</span>
      <span class="word">project</span>
      <br />
      <span class="word">deserves</span>
      <span class="word highlight">the&nbsp;best.</span>
    </h2>

    <!-- Sub + CTA -->
    <div class="cta-sub mt-12 flex flex-col items-center gap-6 opacity-0">
      <p class="text-base text-dark/50 max-w-sm leading-relaxed">
        No guesswork, no delays — just clean work delivered on time and on
        budget.
      </p>
      <Button isNewTab href="https://api.whatsapp.com/send?phone=17049688289">
        Start your project
        <svg
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300"
        >
          <path d="M3 9h12M9 3l6 6-6 6"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>

<style>
  /* Words start invisible, slide up */
  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
    margin-right: 0.22em;
  }

  .word.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Primary highlight words */
  .word.highlight {
    color: var(--color-primary) !important;
  }

  .cta-eyebrow,
  .cta-sub {
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
    transform: translateY(16px);
  }

  .cta-eyebrow.visible,
  .cta-sub.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Staggered word reveal on scroll
  const section = document.getElementById("cta")!;
  const words = section.querySelectorAll<HTMLElement>(".word");
  const eyebrow = section.querySelector<HTMLElement>(".cta-eyebrow")!;
  const sub = section.querySelector<HTMLElement>(".cta-sub")!;

  let triggered = false;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting && !triggered) {
        triggered = true;

        // Eyebrow first
        setTimeout(() => eyebrow.classList.add("visible"), 0);

        // Then each word with a stagger
        words.forEach((word, i) => {
          setTimeout(() => word.classList.add("visible"), 120 + i * 70);
        });

        // Sub + CTA after all words
        const totalDelay = 120 + words.length * 70 + 100;
        setTimeout(() => sub.classList.add("visible"), totalDelay);

        observer.disconnect();
      }
    },
    { threshold: 0.25 },
  );

  observer.observe(section);
</script>
