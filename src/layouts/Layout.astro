---
import "@/styles/global.css";
import "@/styles/theme.css";

import "@fontsource/dm-serif-display";
import "@fontsource-variable/manrope/wght.css";
import SEO from "@/components/SEO.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Torres Home",
  description = "Quality-first construction, remodeling, and interior design across the USA. Est. 2022. Premium drywall, painting, flooring, and carpentry services.",
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4efe6" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} />
    <title>Torres Home</title>
    <meta property="og:title" content="Torres HC" />
    <meta property="og:description" content="Tu descripción aquí" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://torreshc.vercel.app/" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content="/og-image.png" />
  </head>

  <body>
    <a
      href="#main-content"
      class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-dark focus:text-white focus:rounded-lg"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
